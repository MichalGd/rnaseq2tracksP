    given-names: Michal
    orcid: "https://orcid.org/0000-0000-0000-0000"
license: MIT
repository-code: "https://github.com/MichalGd/rnaseq2tracksP"
keywords:
  - RNA-seq
  - bioinformatics
  - DESeq2
  - STAR
  - BigWig
  - UCSC
  - epigenomics
  - chromatin
